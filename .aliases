# git search and replace, original_text = $1, replace_text=$2
function gsed(){
  if [[ "$OSTYPE" =~ ^darwin ]]; then
    git grep -l $1 | xargs sed -i'' -e "s/$1/$2/g"
  else
    git grep -l $1 | xargs sed -i "s/$1/$2/g"
  fi
}

gdiff() {
  preview="git diff $@ --color=always -- {-1} | delta --line-numbers"
  git diff $@ --name-only | fzf -m --ansi --preview $preview
}

batdiff() {
  git diff $@ --name-only --relative --diff-filter=d | xargs bat --diff
}


local dsfpreview="diff-so-fancy | less --tabs=2 -FXRi"

alias glNoGraph='git log --color=always --format="%C(auto)%h%d %s %C(black)%C(bold)%cr% C(auto)%an" "$@"'
glog() {
  local _gitLogLineToHash="echo {} | grep -o '[a-f0-9]\{7\}' | head -1"
  local _viewGitLogLine="$_gitLogLineToHash | xargs -I % sh -c 'git show --color=always % | $dsfpreview'"

   glNoGraph |
    fzf --no-sort --reverse --tiebreak=index --no-multi \
        --ansi --preview="$_viewGitLogLine" \
        --header "enter to view, alt-y to copy hash" \
        --bind "enter:execute:$_viewGitLogLine   | less -R" \
        --bind "alt-y:execute:$_gitLogLineToHash | xclip"
}

# usage:
# gsync develop # will rebase with develop
# gsync develop merge # will merge with develop
gsync() {
  local branch="main" strategy="rebase" do_migrate="no"

  if [[ $# -gt 0 && ! "$1" =~ ^-- ]]; then
    branch="$1"; shift
  fi

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --rebase) strategy="rebase" ;;
      --merge) strategy="merge" ;;
      --migrate) do_migrate="yes" ;;
      --help)
        echo "Usage: gsync [branch] [--rebase|--merge] [--migrate] [--help]"
        echo "Defaults: branch=main, strategy=rebase, migrate=no"
        return 0
        ;;
      *)
        echo "Unknown option: $1"
        return 1
        ;;
    esac
    shift
  done

  echo "🌿 Branch: $branch | ⚙️ Strategy: $strategy | 🔄 Migrate: $do_migrate"

  git checkout "$branch" && git pull && git checkout - && git "$strategy" "$branch"

  if [[ $do_migrate == "yes" && -x "bin/rails" ]]; then
    echo "🚀 Running migrations..."
    bin/rails db:migrate
  fi

  if [[ -f db/structure.sql ]]; then
    echo "🧳 Discarding local changes in db/structure.sql.."
    git checkout -- db/structure.sql
  fi
}


# Sync all projects with remote in the current directory
pullall() {
  # store the current dir
  CUR_DIR=$(pwd)

  # Let the person running the script know what\'s going on.
  echo "\n\e[32mPulling in latest changes for all repositories...\e[0m\n"

  # Find all git repositories and update it to the master latest revision
  for i in $(find . -name ".git" | cut -c 3-); do
      echo "";
      echo "\n\e[33m" + $i + "\e[0m";

      # We have to go to the .git parent directory to call the pull command
      cd "$i";
      cd ..;

      git fetch --prune
      # finally pull
      [[ `git branch --list master` ]] && git fetch origin master:master;
      [[ `git branch --list develop` ]] && git fetch origin develop:develop;

      # lets get back to the CUR_DIR
      cd $CUR_DIR
  done

  echo "\n\e[32mComplete!\e[0m\n"
}

rspec-diff() {
  local diff_args=()
  local dry_run=false

  for arg in "$@"; do
    case "$arg" in
      --dry-run) dry_run=true ;;
      *) diff_args+=("$arg") ;;
    esac
  done

  local files
  files=$(git diff "${diff_args[@]}" -U0 -- '*_spec.rb' |
    awk '
      /^\+\+\+ b\// { file = substr($0, 7); next }
      /^@@/ {
        split($0, a, "+"); split(a[2], b, " "); split(b[1], r, ",")
        start = r[1]; len = (r[2]?r[2]:1); end = start + len - 1

        if (!(file in min)) { min[file]=start; max[file]=end }
        else {
          if (start < min[file]) min[file]=start
          if (end > max[file])   max[file]=end
        }
      }
      END {
        for (f in min)
          print f ":" min[f] ":" max[f]  # output only to stdout
      }
    ' |
    sort -u
  )

  if [ -z "$files" ]; then
    [ "$dry_run" = true ] && echo "Dry-run: no spec changes detected" >&2
    return
  fi

  if [ "$dry_run" = true ]; then
    echo "Dry-run mode: changed spec files would be:" >&2
    echo "$files"
    return
  fi

  # Only output the file list to stdout for piping
  echo "$files"
}

