alias localIp="ifconfig | sed -En 's/127.0.0.1//;s/.*inet (addr:)?(([0-9]*\.){3}[0-9]*).*/\2/p'"

# Loop helper function
function repeat() {
  local times=$1   # number of times to repeat
  shift            # shift arguments so $@ now contains the command/block
  for i in $(seq 1 $times); do
    echo "========== Run #$i =========="
    "$@"
    echo ""
  done
}

# find all files with a given extension
function findf() {
  find . -name "*$1" -type f
}

# find and delete all files with a given extension
function deletef() {
  find . -name "*$1" -type f -delete
}

# preview csv files. source: http://stackoverflow.com/questions/1875305/command-line-csv-viewer
function csv(){
  sed 's/,,/, ,/g;s/,,/, ,/g' "$@" | column -s, -t | less -#2 -N -S
}

# animated gifs from any video
function gify() {
  start=`date +%s`
  # Usage function, displays valid arguments
  usage() { echo "$0: [-f <fps, defaults to 15>] [-w <width, defaults to 840] inputfile" 1>&2; return 0; }

  # Default variables
  fps=15
  width=840

  # getopts to process the command line arguments
  while getopts ":f:w:" opt; do
      case "${opt}" in
          f) fps=${OPTARG};;
          w) width=${OPTARG};;
          *) usage && return;;
      esac
  done

  # shift out the arguments already processed with getopts
  shift "$((OPTIND - 1))"
  if (( $# == 0 )); then
      echo >&2 'Missing input file\n'
      usage >&2
      return
  fi

  # set input variable to the first option after the arguments
  input="$1"

  # Extract filename from input file without the extension
  filename=$(basename "$input")
  #extension="${filename##*.}"
  filename="${filename%.*}.gif"

  # Debug display to show what the script is using as inputs
  echo "Input: $#"
  echo "Output: $filename"
  echo "FPS: $fps"
  echo "Width: $width"

  # temporary file to store the first pass pallete
  palette="/tmp/palette.png"

  # options to pass to ffmpeg
  filters="fps=$fps,scale=$width:-1:flags=lanczos"

  # ffmpeg first pass
  ffmpeg -v error -i "$input" -vf "$filters,palettegen" -y $palette

  # ffmpeg second pass
  ffmpeg -v error -i "$input" -i $palette -lavfi "$filters [x]; [x][1:v] paletteuse=dither=bayer:bayer_scale=3" -y "$filename"

  end=`date +%s`
  runtime=$((end-start))

  # display output file size
  filesize=$(du -h "$filename" | cut -f1)
  echo "\nOutput File Name: $filename"
  echo "Output File Size: $filesize"
  echo "Time taken: $runtime seconds"
}

function gitwk() {
  local wk_cmd="$1"
  local branch="$2"
  [[ -z "$wk_cmd" || -z "$branch" ]] && { echo "Usage: gitwk add|remove <branch>"; return 1; }

  # --- Short directory name from branch ---
  local dir=$(echo "$branch" | awk -F '[-/]' '{print $1 "_" $2}')

  # --- Repo root ---
  local repo_root
  repo_root="$(git rev-parse --show-toplevel 2>/dev/null)" || { echo "❌ Not in a git repository"; return 1; }
  local wk_path="../worktrees/$dir"

  case "$wk_cmd" in
    add)
      mkdir -p "$repo_root/worktrees"

      if [ -d "$wk_path" ]; then
        echo "🔄 Switching to existing worktree $wk_path"
      else
        echo "🌿 Adding worktree for $branch at $wk_path"

        # Ensure branch exists locally, create if not
        if ! git show-ref --verify --quiet "refs/heads/$branch"; then
          echo "🌱 Branch $branch not found locally. Creating..."
          git branch "$branch" || { echo "❌ Failed to create branch $branch"; return 1; }
        fi

        git worktree add "$wk_path" "$branch" || { echo "❌ Failed to add worktree"; return 1; }

        # --- Copy top-level hidden files and .config ---
        echo "📋 Copying top-level hidden files and .config..."
        cd "$repo_root" || return 1
        if command -v fd >/dev/null 2>&1; then
          fd --hidden --no-ignore-vcs --max-depth 1 --exclude .git -t f -x cp {} "$wk_path"
        else
          find . -maxdepth 1 -type f -name ".*" ! -name ".git" -exec cp {} "$wk_path" \;
        fi
        [ -d ./config ] && cp -r ./config "$wk_path"
      fi

      mise trust "$wk_path/mise.toml"
      cd $wk_path

      echo "✅ Path: $PWD"
      ;;
    remove)
      if [ -d "$wk_path" ]; then
        echo "🗑️  Removing worktree $wk_path"
        git worktree remove "$wk_path" || { echo "❌ Failed to remove worktree"; return 1; }
        rm -rf "$wk_path"   # optional cleanup
      else
        echo "⚠️  No worktree for branch $branch"
      fi
      ;;
    *)
      echo "❓ Unknown command $wk_cmd. Use add|remove."
      ;;
  esac
}
