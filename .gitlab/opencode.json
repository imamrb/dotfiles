{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "gkg": {
      "enabled": true,
      "type": "remote",
      "url": "http://localhost:27495/mcp"
    },
    "gitlab": {
      "enabled": false,
      "type": "remote",
      "url": "https://gitlab.com/api/v4/mcp"
    },
    "glean": {
      "enabled": false,
      "type": "remote",
      "url": "https://gitlab-be.glean.com/mcp/default"
    },
    "gitlab-orbit": {
      "type": "remote",
      "url": "https://gitlab.com/api/v4/orbit/mcp"
    }
  },
  "instructions": [
    "AGENTS.local.md"
  ],
  "default_agent": "sisyphus",
  "model": "gitlab/duo-chat-sonnet-4-6",
  "small_model": "gitlab/duo-chat-haiku-4-5",
  "share": "disabled",
  "permission": {
    "bash": {
      "*": "allow",
      "rm -rf *": "deny",
      "glab *": "allow",
      "python3 *": "allow",
    },
    "edit": {
      "*": "allow",
      ".env": "deny",
      ".env.*": "deny",
      "config/secrets.yml": "deny",
      "config/credentials.yml.enc": "deny",
      "config/master.key": "deny"
    },
    "read": {
      "*": "allow",
      "~/.aws/*": "deny",
      "~/.ssh/*": "deny",
      "~/.gnupg/*": "deny",
      "~/.netrc": "deny",
      "~/.config/opencode/*": "deny"
    }
  },
  "lsp": {
    "ruby": {
      "command": "ruby-lsp"
    }
  }
}
